model RentalRequest {
  id String @id @default(uuid())

  message String?

  startDate       DateTime
  durationMonths Int

  status RentalStatus @default(PENDING)

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   User   @relation("TenantRentals", fields: [tenantId], references: [id], onDelete: Cascade)

  payment Payment?
  review  Review?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rental_requests")
}
